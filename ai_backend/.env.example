# Workhorse AI Backend Configuration

# AI Provider: "ollama" or "vllm"
AI_PROVIDER=ollama

# Ollama API endpoint (default: local)
OLLAMA_URL=http://localhost:11434

# vLLM API endpoint (if using vLLM)
VLLM_URL=http://localhost:8000

# Default LLM model
# CodeLlama options: codellama:7b, codellama:13b, codellama:34b
# Mistral options: mistral:7b
# Neural Chat: neural-chat:7b
DEFAULT_MODEL=codellama:7b

# Chat model (optional; defaults to DEFAULT_MODEL)
# Recommended for conversational quality: gemma3:4b or mistral:7b
CHAT_MODEL=gemma3:4b

# Adaptive model routing (recommended)
# true: pick strongest installed model that fits detected VRAM
# false: use DEFAULT_MODEL/CHAT_MODEL directly
ADAPTIVE_MODEL_ROUTING=true

# Optional manual override if GPU auto-detection is unavailable
# Example: RTX 3080 10GB -> GPU_VRAM_GB_OVERRIDE=10
# GPU_VRAM_GB_OVERRIDE=10

# Keep this much VRAM free when selecting a model (GB)
MODEL_VRAM_HEADROOM_GB=1.0

# Python backend port
AI_BACKEND_PORT=8888

# NVIDIA GPU settings (optional, set to optimization level)
# NVIDIA_CUDA_COMPUTE_MODE=0  # Default
# CUDA_VISIBLE_DEVICES=0      # Use GPU 0 (if multiple GPUs)

# AMD GPU settings (optional)
# USE_ROCM=1
# ROCM_DEVICES=0
